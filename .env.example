# Dubicolt Automotive API
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (required — API will not start without these)
DB_NAME=dubicolt_automotive
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432
# Remote/cloud DB: SSL is auto-enabled when DB_HOST is not localhost
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_LOGGING=true

# Azure Blob Storage (product images, part request photos)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=dubicolt-uploads

# M-Pesa (optional — without these, STK push auto-completes in sandbox mode)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=

# Seed login (password: Dubicolt123!)
# admin@dubicolt.com — role admin
# buyer@test.com — role buyer
